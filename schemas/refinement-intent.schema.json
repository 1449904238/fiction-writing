{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fiction-writing/schemas/refinement-intent.schema.json",
  "title": "精修意图包 (Refinement Intent Package)",
  "description": "精修意图包 JSON Schema 定义文件。04 精修完成后输出此结构化数据，随正文传递给 05 去AI味精修师。记录 04 的打磨决策，使 05 能精准跳过已处理项、聚焦残留风险，避免全量重扫。对应 references/_archive/04_交接协议.md 第二章与 05_去AI味精修师.md Gate 3/Gate 11 的意图包读取逻辑。",
  "type": "object",
  "required": ["chapter_no", "processed_items"],
  "properties": {
    "chapter_no": { "type": "integer" },
    "processed_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "status", "gate_id"],
        "properties": {
          "category": { "enum": ["psychological_direct", "explanation_tone", "metaphor_quality", "sensory_redirect", "dialogue_subtext"] },
          "status": { "enum": ["fully_processed", "partially_processed", "skipped"] },
          "gate_id": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "boundary_ambiguous_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["location", "description", "gate_id"],
        "properties": {
          "location": { "type": "string" },
          "description": { "type": "string" },
          "gate_id": { "type": "string" }
        }
      }
    }
  }
}
